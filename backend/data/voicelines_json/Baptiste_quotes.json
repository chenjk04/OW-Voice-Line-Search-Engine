    "ID": "e892f3b80dcb9c7f1f54edce03bf16a2",
    "line": "Expand Poze ou. English: Settle down.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/33/Baptiste_-_%28Haitian_Creole%29_Settle_down.ogg/revision/latest?cb=20230913123923"
  },
  {
    "hero": "Baptiste",
    "ID": "2f956054c9c55d8e4fe0f7d31c2fe9b0",
    "line": "Expand Kou lan guet! English: Damn!",
