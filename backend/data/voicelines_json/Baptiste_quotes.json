[
  {
    "hero": "Baptiste",
    "ID": "1745063769e5d1acc46cb64e61c7cd94",
    "line": "Do you want a bandage for that?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/20/Baptiste_-_Do_you_want_a_bandage_for_that.ogg/revision/latest?cb=20230913124128"
  },
  {
    "hero": "Baptiste",
    "ID": "aef58777fc9b30453d05b12cb7483066",
    "line": "Come with me if you want to live.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0b/Baptiste_-_Come_with_me_if_you_want_to_live.ogg/revision/latest?cb=20230913124110"
  },
  {
    "hero": "Baptiste",
    "ID": "9188530e5cc22807a4e84d36360a5507",
    "line": "Do I look like an angel of mercy to you?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/fd/Baptiste_-_Do_I_look_like_an_angel_of_mercy_to_you.ogg/revision/latest?cb=20230913124126"
  },
  {
    "hero": "Baptiste",
    "ID": "15bbe585a11f717364737f95c4f59f04",
    "line": "I'll recommend not dying.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/a8/Baptiste_-_I_recommend_not_dying.ogg/revision/latest?cb=20230913124440"
  },
  {
    "hero": "Baptiste",
    "ID": "a55bd685db76f0290bad7a00cdc0ee08",
    "line": "Let me buy you a drink.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/de/Baptiste_-_Let_me_buy_you_a_drink.ogg/revision/latest?cb=20230913124624"
  },
  {
    "hero": "Baptiste",
    "ID": "2197adeb86df2963abbdb85aeac85fca",
    "line": "Looks like that apple a day thing didn't work out for you.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/13/Baptiste_-_Looks_like_that_apple_a_day_thing_didn%27t_work_out_for_you.ogg/revision/latest?cb=20230913124708"
  },
  {
    "hero": "Baptiste",
    "ID": "793dd5d6a803814facfa5d6663bcceb3",
    "line": "\"Thank you, Baptiste.\" Oh, you're welcome.",
