  },
  {
    "hero": "Baptiste",
    "ID": "fe1949d2f2758f3f25a6d116ebd528ab",
    "line": "Time's up, pencils down.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/38/Baptiste_-_Time%27s_up%2C_pencils_down.ogg/revision/latest?cb=20230913125209"
  },
  {
