  },
  {
    "hero": "Brigitte",
    "ID": "50a13a2602a1ac1290212f12fc33378e",
    "line": "Expand God Jul! English: Merry Christmas!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/4a/Brigitte_-_%28Swedish%29_Merry_Christmas.ogg/revision/latest?cb=20230913130247"
  },
  {
    "hero": "Brigitte",
    "ID": "f31f4e3ff6860ec07daf7d0b4b100b24",
