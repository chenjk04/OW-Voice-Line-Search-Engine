  },
  {
    "hero": "Brigitte",
    "ID": "b76510ec0308742848b34d1060aea598",
    "line": "Expand Skål! English: Cheers!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/ae/Brigitte_-_%28Swedish%29_Cheers.ogg/revision/latest?cb=20230913130220"
  },
  {
    "hero": "Brigitte",
    "ID": "55bdc9ce81fcfb1c4365e87dfc7025f3",
