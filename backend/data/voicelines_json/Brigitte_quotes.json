    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/9d/Brigitte_-_Hard_work_pays_off.ogg/revision/latest?cb=20230913130655"
  },
  {
    "hero": "Brigitte",
    "ID": "d212277ab3cef1d9f04510caa33af6c7",
    "line": "Time to roll up my sleeves.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/49/Brigitte_-_Time_to_roll_up_my_sleeves.ogg/revision/latest?cb=20230913131610"
  },
  {
    "hero": "Brigitte",
    "ID": "1083bb6808eaf8e486f00054a284e885",
    "line": "Expand Skägget i brevlådan. English: Don't get caught red-handed. (Literal meaning: Don't get stuck with your beard in the letterbox.)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/2a/Brigitte_-_%28Swedish%29_Don%27t_get_caught_with_your_beard_in_the_litterbox.ogg/revision/latest?cb=20230913130225"
  },
  {
    "hero": "Brigitte",
    "ID": "68cdae05dfc5c8655886ae6fa67e7112",
    "line": "Expand Som man bäddar får man ligga. English: If you make your bed, lie in it.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/4c/Brigitte_-_%28Swedish%29_If_you_make_your_bed%2C_lie_in_it.ogg/revision/latest?cb=20230913130243"
  },
  {
    "hero": "Brigitte",
    "ID": "a20838513f0fffbdd83aebe9409b8afa",
    "line": "Expand Du gör en höna av en fjäder. English: You're making a chicken out of a feather.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/77/Brigitte_-_%28Swedish%29_You%27re_making_a_chicken_out_of_a_feather.ogg/revision/latest?cb=20230913130311"
  },
  {
    "hero": "Brigitte",
    "ID": "baafdaf867eb03363fa3bd3f1001f5dd",
    "line": "It's just a flesh wound.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/be/Brigitte_-_It%27s_just_a_flesh_wound.ogg/revision/latest?cb=20230913130938"
  },
  {
    "hero": "Brigitte",
    "ID": "41ff171692cc0d591e91dbe0d2181586",
    "line": "Leave this to an expert.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8a/Brigitte_-_Leave_this_to_an_expert.ogg/revision/latest?cb=20230913130957"
  },
  {
    "hero": "Brigitte",
    "ID": "325516fd6d23d257b3cd09479603f930",
    "line": "Expand Gå och dra något gammalt över dig! English: Get lost! (Literal meaning: Go and pull something old over yourself!)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1b/Brigitte_-_%28Swedish%29_Get_lost.ogg/revision/latest?cb=20230913130231"
  },
  {
    "hero": "Brigitte",
    "ID": "4257f6c680a93309ccd13679aa6cc95f",
    "line": "Expand Ingen ko på isen. English: Don't worry about it. (Literal meaning: There's no cow on the ice.)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f0/Brigitte_-_%28Swedish%29_No_worries.ogg/revision/latest?cb=20230913130249"
  },
  {
    "hero": "Brigitte",
    "ID": "7abfe653e07285e9a856b8ee76abc247",
    "line": "That's the Lindholm way!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/44/Brigitte_-_That%27s_the_Lindholm_way.ogg/revision/latest?cb=20230913131429"
  },
  {
    "hero": "Brigitte",
    "ID": "6488fe1ba3e38958662aaa7ad6a3d7c7",
    "line": "Expand Dra åt skogen! English: Piss off! (Literal meaning: Go to the forest!)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8c/Brigitte_-_%28Swedish%29_Get_lost_%282%29.ogg/revision/latest?cb=20240508041902"
  },
  {
    "hero": "Brigitte",
    "ID": "fef5a24a6253fe5666f7b3ae83d51d10",
    "line": "Yield to my shield!",
    "audio_url": null
  }
