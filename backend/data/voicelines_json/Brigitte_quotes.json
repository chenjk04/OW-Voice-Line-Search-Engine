    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/e2/Brigitte_-_Who%27s_ready_to_party.ogg/revision/latest?cb=20230913131759"
  },
  {
    "hero": "Brigitte",
    "ID": "8abfb8e7a33b138bea4cce774e795e87",
    "line": "Expand Allt som glimmar är inte guld. English: All that glitters isn't gold.",
