    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/15/Cassidy_-_This_calls_for_a_celebration.ogg/revision/latest?cb=20250830042203"
  },
  {
    "hero": "Cassidy",
    "ID": "8cb43b507a10f004ad7588cc37d8662c",
    "line": "Ugh. Think I need a little hair of the dog.",
