  {
    "hero": "Cassidy",
    "ID": "47e5f58fc0021600a005f4f9d3e12634",
    "line": "After you.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/92/Cassidy_-_After_you.ogg/revision/latest?cb=20230913131932"
  },
  {
    "hero": "Cassidy",
    "ID": "c7260e1a143a66c3408f1bb4cf8b8558",
    "line": "Happens to the best of us.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/ba/Cassidy_-_Happens_to_the_best_of_us.ogg/revision/latest?cb=20230913132319"
  },
  {
    "hero": "Cassidy",
    "ID": "23c6bed1750cae6ef80466c8a9c71115",
    "line": "I tried being reasonable. Didn't take to it.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/90/Cassidy_-_I_tried_being_reasonable._Didn%27t_take_to_it.ogg/revision/latest?cb=20250830041611"
  },
  {
    "hero": "Cassidy",
    "ID": "16f795df607ccf4f9706309f9c28ae6a",
    "line": "I'm not good. I'm not bad. But I sure as hell ain't ugly.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/55/Cassidy_-_I%27m_not_good._I%27m_not_bad._But_I_sure_as_hell_ain%27t_ugly.ogg/revision/latest?cb=20231213175706"
  },
  {
    "hero": "Cassidy",
    "ID": "540fafdd3bd0f23442bea34a8b1a3063",
    "line": "I'm the quick. You're the dead.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1d/Cassidy_-_I%27m_the_quick._You%27re_the_dead.ogg/revision/latest?cb=20250830041641"
  },
  {
    "hero": "Cassidy",
    "ID": "8983553442e85e8d044e6195b8161a5d",
    "line": "I'm your huckleberry.",
