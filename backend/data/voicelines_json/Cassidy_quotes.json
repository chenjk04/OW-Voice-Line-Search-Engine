  },
  {
    "hero": "Cassidy",
    "ID": "16f0a3af20b09187438a5dbdf8925991",
    "line": "I've got a bullet with your name on it.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/17/Cassidy_-_I%27ve_got_a_bullet_with_your_name_on_it.ogg/revision/latest?cb=20250830041712"
  },
  {
    "hero": "Cassidy",
    "ID": "3c682e1743cefd67ce0bbe5f9b0d31e4",
    "line": "Reach for the sky.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f6/Cassidy_-_Reach_for_the_sky.ogg/revision/latest?cb=20250830042012"
  },
  {
    "hero": "Cassidy",
    "ID": "9dfc6706374f6f128f6a723d5230809b",
    "line": "Wanted: dead or alive.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f9/Cassidy_-_Wanted%2C_dead_or_alive.ogg/revision/latest?cb=20250830042229"
  },
  {
    "hero": "Cassidy",
    "ID": "e6935042129937250bc2e641a7380d19",
    "line": "You done?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/38/Cassidy_-_You_done.ogg/revision/latest?cb=20250830042344"
  },
  {
    "hero": "Cassidy",
    "ID": "296e56c392f99ff511d7c1a6d87cc820",
    "line": "You seem familiar. Ain't I killed you before?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8a/Cassidy_-_You_seem_familiar._Ain%27t_I_killed_you_before.ogg/revision/latest?cb=20230913133558"
  },
  {
    "hero": "Cassidy",
    "ID": "f22d43a5b8d7742aa55a5b34a9b7354f",
    "line": "Boom goes the dynamite.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/56/Cassidy_-_Boom_goes_the_dynamite.ogg/revision/latest?cb=20250830041245"
  },
  {
    "hero": "Cassidy",
    "ID": "e9f18ff517c719359865fde094c35f5c",
    "line": "I don't much like losin'.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/be/Cassidy_-_I_don%27t_much_like_losin.ogg/revision/latest?cb=20231213175545"
  },
  {
    "hero": "Cassidy",
    "ID": "e7f16913204012b8ecb43bb25e891248",
    "line": "I hear you, pumpkin.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/44/Cassidy_-_I_hear_you%2C_pumpkin.ogg/revision/latest?cb=20231213181146"
  },
  {
    "hero": "Cassidy",
    "ID": "421150725983391446dc9fb94f5a6eb4",
    "line": "Hmph. It's your funeral.",
