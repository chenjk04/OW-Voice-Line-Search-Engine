    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/24/Cassidy_-_Buckle_up.ogg/revision/latest?cb=20250830041249"
  },
  {
    "hero": "Cassidy",
    "ID": "72fa761305b9cec2938225683ba1bb03",
