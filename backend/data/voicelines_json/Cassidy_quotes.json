  },
  {
    "hero": "Cassidy",
    "ID": "af1d72403ebc47f09ccf8682a20a2d76",
    "line": "Take my advice: you oughta stay down.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/4e/Cassidy_-_Take_my_advice%2C_you_oughta_stay_down.ogg/revision/latest?cb=20230913133110"
  },
  {
    "hero": "Cassidy",
    "ID": "5448040fafff697310f2afffaa6fea87",
    "line": "That went against my better nature.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/bc/Cassidy_-_That_went_against_my_better_nature.ogg/revision/latest?cb=20230913133136"
  },
  {
    "hero": "Cassidy",
    "ID": "6d3bf5a657f2a2fcb65e1f102fd799c7",
