  },
  {
    "hero": "Cassidy",
    "ID": "e06a45bbcf5b8b1609a3485334c4b436",
    "line": "Trick or treat.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/dc/Cassidy_-_Trick_or_treat.ogg/revision/latest?cb=20250830042227"
  },
  {
    "hero": "Cassidy",
    "ID": "8be09bc5f053cd2ccaf7db30c25f253d",
    "line": "You were already dead.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/cb/Cassidy_-_You_were_already_dead.ogg/revision/latest?cb=20250830042405"
  },
  {
    "hero": "Cassidy",
    "ID": "7b61b47e219a5f1e530616b6d166db70",
    "line": "Someone had to break the ice.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1f/Cassidy_-_Someone_had_to_break_the_ice.ogg/revision/latest?cb=20250830042038"
  },
  {
    "hero": "Cassidy",
    "ID": "4eb45263eea66c8f1920b2efab0a7205",
    "line": "You've been snowed in.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/14/Cassidy_-_You%27ve_been_snowed_in.ogg/revision/latest?cb=20250830042414"
  },
  {
    "hero": "Cassidy",
    "ID": "282e78e8aa5bea8670e1267c18d1149a",
    "line": "How's that for some fireworks?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/00/Cassidy_-_How%27s_that_for_some_fireworks.ogg/revision/latest?cb=20230913132411"
  },
  {
    "hero": "Cassidy",
    "ID": "bdcbe1a70a6199f6f170981058a68b9e",
    "line": "I'll have another!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/10/Cassidy_-_I%27ll_have_another.ogg/revision/latest?cb=20250830041618"
  },
  {
    "hero": "Cassidy",
    "ID": "4d994a47b287809c8d81400b2adf63c3",
