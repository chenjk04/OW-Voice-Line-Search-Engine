  },
  {
    "hero": "Cassidy",
    "ID": "d898c4b71bf198c531b903ace08acc3d",
    "line": "Don't sass me.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/c4/Cassidy_-_Don%27t_sass_me.ogg/revision/latest?cb=20250830041343"
  },
  {
    "hero": "Cassidy",
    "ID": "7dd0aeb868a60be233c9f76e4d5ac2a5",
    "line": "Guess we'll do this the old fashioned way.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/74/Cassidy_-_Guess_we%27ll_do_this_the_old_fashioned_way.ogg/revision/latest?cb=20250830041456"
  },
  {
    "hero": "Cassidy",
    "ID": "56ee20aef54183da1010137dab575eb0",
    "line": "I ain't gathering no moss.",
