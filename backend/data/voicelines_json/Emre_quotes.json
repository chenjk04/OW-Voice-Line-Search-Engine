[
  {
    "hero": "Emre",
    "ID": "b0e266e9192281d75bfbd7893e19d7db",
    "line": "Keep up the good fight. It's worth it.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/16/Emre_-_Keep_up_the_good_fight._It%27s_worth_it.ogg/revision/latest?cb=20260220084157"
  },
  {
    "hero": "Emre",
    "ID": "a75b6ed213c0b625d127ae3298339f62",
    "line": "Expand Tatlı yiyelim, tatlı konuşalım. (Turkish) English: Let's eat sweet, so we can talk sweet.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/7d/Emre_-_%28Turkish%29_Let%E2%80%99s_eat_sweet%2C_so_we_can_talk_sweet.ogg/revision/latest?cb=20260220083826"
  },
  {
    "hero": "Emre",
    "ID": "311399a82baa1e7c8189f84d5fdadda8",
    "line": "Expand Sorun mu var? Bana vız gelir tırıs gider. (Turkish) English: Is there a problem? I don't care at all.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/17/Emre_-_%28Turkish%29_Is_there_a_problem._It%27s_nothing_to_me.ogg/revision/latest?cb=20260220083825"
  },
  {
    "hero": "Emre",
    "ID": "2d4983b1f578b3446a942ec46e35a3a9",
    "line": "Open sesame.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/74/Emre_-_Open_sesame.ogg/revision/latest?cb=20260220084307"
  },
  {
    "hero": "Emre",
    "ID": "84d68b6f77b56a3103aeef6aaa6d6ff4",
    "line": "That's a road I won't go down.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8c/Emre_-_That%27s_a_road_I_won%27t_go_down.ogg/revision/latest?cb=20260220084419"
  },
  {
    "hero": "Emre",
    "ID": "da45f2ce616c9c3cf129fa05d5d50db8",
    "line": "I'll sleep when I'm dead.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/59/Emre_-_I%27ll_sleep_when_I%27m_dead.ogg/revision/latest?cb=20260220084127"
  },
  {
    "hero": "Emre",
    "ID": "8bcc420e2a6111e5e8f2b29c04f187b9",
    "line": "You ought to tread lightly.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/a2/Emre_-_You_ought_to_tread_lightly.ogg/revision/latest?cb=20260220084612"
  },
  {
    "hero": "Emre",
    "ID": "95ee3f68daf8c53de6794aea4685b39d",
    "line": "I don't trust easy.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/99/Emre_-_I_don%27t_trust_easy.ogg/revision/latest?cb=20260220084102"
  },
  {
    "hero": "Emre",
    "ID": "984c49facd9375dd25c64b5b932b2908",
    "line": "Well, look who it is!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/9e/Emre_-_Well%2C_look_who_it_is.ogg/revision/latest?cb=20260220084536"
  },
  {
    "hero": "Emre",
    "ID": "aa02b6de10ba488ce75b0e052e74e9d3",
    "line": "Funny thing about tough calls. They're usually the right ones.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/2b/Emre_-_Funny_thing_about_tough_calls._They%27re_usually_the_right_ones.ogg/revision/latest?cb=20260220084010"
  },
  {
    "hero": "Emre",
    "ID": "2c1f00418265e892ba9374da1490d436",
    "line": "Look who's back for more!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/e7/Emre_-_Look_who%27s_back_for_more.ogg/revision/latest?cb=20260220084218"
  },
  {
    "hero": "Emre",
    "ID": "9fa059a0e56a1697b61e073a65c7c6ac",
    "line": "So... what are we?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/22/Emre_-_So..._what_are_we.ogg/revision/latest?cb=20260220084344"
  },
  {
    "hero": "Emre",
    "ID": "05f47b624866471340cae1f57e486479",
    "line": "You're off by a hare.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/29/Emre_-_You%27re_off_by_a_hare.ogg/revision/latest?cb=20260424093511"
  },
  {
    "hero": "Emre",
    "ID": "1ceee107a919d9ec1a8ab8bddfad488f",
    "line": "I'll keep fighting, no matter what it costs me.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/cd/Emre_-_I%E2%80%99ll_keep_fighting%2C_no_matter_what_it_costs_me.ogg/revision/latest?cb=20260220084117"
  }
]