  },
  {
    "hero": "Mei",
    "ID": "fff2be136022d8d3d1ed27e6136e274b",
    "line": "The cold never bothered me anyway.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/6/65/Mei_-_The_cold_never_bothered_me_anyway.ogg/revision/latest?cb=20230914113900"
  },
  {
    "hero": "Mei",
    "ID": "ceb0d9eda8318160255c786f6bdc8554",
    "line": "I feel like dancing!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/9c/Mei_-_I_feel_like_dancing.ogg/revision/latest?cb=20230914113117"
  },
  {
    "hero": "Mei",
    "ID": "d112dd03692032effb49670b8ea6e011",
    "line": "Expand Gõng xǐ fā cái! Hanzi: 恭喜发财！ English: Wishing you prosperity!/May you have a prosperous New Year!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/d9/Mei_-_%28Chinese%29_Be_happy_and_prosperous.ogg/revision/latest?cb=20230914112456"
  },
  {
    "hero": "Mei",
    "ID": "38de186cd8503e308fe709561411d121",
    "line": "Expand Hóngbāo ná lái. Hanzi: 红包拿来。 English: Give me a red envelope.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/88/Mei_-_%28Chinese%29_Give_me_a_red_envelope.ogg/revision/latest?cb=20230914112510"
  },
  {
    "hero": "Mei",
    "ID": "f5a7cbdd239b5d90bb2f77e681275526",
    "line": "Expand Hǔ nián kuàilè. Hanzi: 虎年快乐。 English: Happy year of the tiger.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/6/6f/Mei_-_%28Chinese%29_Happy_Year_of_the_Tiger.ogg/revision/latest?cb=20230914112512"
  },
  {
    "hero": "Mei",
    "ID": "e33dd711cd52ea8158260466443d431e",
    "line": "Expand Lóng nián kuàilè! Hanzi: 龙年快乐！ English: Happy year of the dragon!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/d2/Mei_-_%28Chinese%29_Happy_year_of_the_dragon%21.ogg/revision/latest?cb=20240212143057"
  },
  {
    "hero": "Mei",
    "ID": "511d142349d4a791250a58bd5c4ddeb6",
    "line": "Expand Moo! Niú nián kuàilè! Hanzi: Moo! 牛年快乐！ English: Moo! Happy year of the ox!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/45/Mei_-_%28Chinese%29_Moo%21_Happy_Year_of_the_Ox.ogg/revision/latest?cb=20230914112532"
  },
  {
    "hero": "Mei",
    "ID": "e79d72f93993f3244b1b1f5e5488d3b2",
    "line": "Every day is a new adventure.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1a/Mei_-_Every_day_is_a_new_adventure.ogg/revision/latest?cb=20230914112924"
  },
  {
    "hero": "Mei",
    "ID": "9d11e31eeea32f565c3636c3a9cbcb6e",
    "line": "I'm going to have to science the heck out of this.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/e3/Mei_-_I%27m_going_to_have_to_science_the_heck_out_of_this.ogg/revision/latest?cb=20230914113235"
  },
  {
    "hero": "Mei",
    "ID": "1dce65e8d538fc2b867b1e121abf8bdf",
    "line": "I'm just a scientist.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/fa/Mei_-_I%27m_just_a_scientist.ogg/revision/latest?cb=20230914113240"
  },
  {
    "hero": "Mei",
    "ID": "dd96398d675431bf2e296cf1239c45ac",
    "line": "I'm sure there's a reasonable scientific explanation for this.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8e/Mei_-_I%27m_sure_there%27s_a_reasonable_scientific_explanation_for_this.ogg/revision/latest?cb=20230914113301"
  },
  {
    "hero": "Mei",
    "ID": "3b5302b741a591485f326c48dc027fba",
    "line": "I was only trying to help!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1e/Mei_-_I_was_only_trying_to_help.ogg/revision/latest?cb=20230914113216"
  },
  {
    "hero": "Mei",
    "ID": "6364d53d1596e8861a9943dce5a9fcd1",
    "line": "So mean! Honestly...",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/02/Mei_-_So_mean%21_Honestly.ogg/revision/latest?cb=20230914113754"
  },
  {
    "hero": "Mei",
    "ID": "25df4b6e88e7dcfa23c12a56d2b1a895",
    "line": "Wake up, sleepyhead!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/59/Mei_-_Wake_up%2C_sleepyhead.ogg/revision/latest?cb=20230914114053"
  },
  {
    "hero": "Mei",
    "ID": "f83fa144fc2f096e44d241447201227f",
    "line": "Expand Bào qiàn!... Bào qiàn. Wǒ hěn bào qiàn. Duì bù qǐ. Hanzi: 抱歉。 抱歉。 我很抱歉。 对不起。 English: Sorry. Sorry. I'm very sorry. I'm sorry.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/e8/Mei_-_%28Chinese%29_Sorry..._sorry..._sorry.ogg/revision/latest?cb=20230914112548"
  },
  {
    "hero": "Mei",
    "ID": "00cbe5ba630eb672edee93325e8cf240",
    "line": "Expand Yú gōng yí shān! Hanzi: 愚公移山！ English: With persistence, we can move mountains!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/fc/Mei_-_%28Chinese%29_With_persistence%2C_we_can_move_mountains.ogg/revision/latest?cb=20230914112605"
  },
  {
    "hero": "Mei",
    "ID": "b52102ed38d86f355b6b0818f72fe133",
    "line": "Wrong place, wrong time!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8d/Mei_-_Wrong_place%2C_wrong_time%21.ogg/revision/latest?cb=20240212134621"
  },
  {
    "hero": "Mei",
    "ID": "fea10435f866e052fe49ce253be413e0",
    "line": "So strange!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8f/Mei_-_So_strange.ogg/revision/latest?cb=20240220135118"
  },
  {
    "hero": "Mei",
    "ID": "0b232bb417b530f474a0ff4f0adf3d01",
    "line": "Love is brightest in the dark.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/58/Mei_-_Love_is_brightest_in_the_dark.ogg/revision/latest?cb=20241221073631"
  }
