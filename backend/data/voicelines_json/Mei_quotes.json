  },
  {
    "hero": "Mei",
    "ID": "cafcf2dd66f14032cc8b424daa24a1ee",
    "line": "Expand Zhè ge shì jiè zhí dé wǒ men fèn zhàn! Hanzi: 这个世界值得我们奋斗！ English: The world is worth fighting for!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/e1/Mei_-_%28Chinese%29_Our_world%27s_worth_fighting_for.ogg/revision/latest?cb=20230914112543"
  },
  {
