    "ID": "df5a08f65bd54cf9d1744beedd0d59b1",
    "line": "I tried my best.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/ee/Mei_-_I_tried_my_best.ogg/revision/latest?cb=20230914113215"
