[
  {
    "hero": "Moira",
    "ID": "5c71b191f86a555a24b281edf81e91a4",
    "line": "What an interesting hypothesis.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/72/Moira_-_What_an_interesting_hypothesis.ogg/revision/latest?cb=20230914121550"
  },
  {
    "hero": "Moira",
    "ID": "03371e1be931a9aca9cedcaf3dda994d",
    "line": "Are you finished?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f5/Moira_-_Are_you_finished.ogg/revision/latest?cb=20230914120337"
  },
  {
    "hero": "Moira",
    "ID": "e70df93705aeb0baae173bf9a06a333e",
    "line": "Biology's habits are hard to break.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/6/61/Moira_-_Biology%27s_habits_are_hard_to_break.ogg/revision/latest?cb=20230914120402"
  },
  {
    "hero": "Moira",
    "ID": "4a70f58f2b2c8c3eb81fc58092c57f5e",
    "line": "Brilliant.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/72/Moira_-_Brilliant.ogg/revision/latest?cb=20230914120407"
  },
  {
    "hero": "Moira",
    "ID": "96d5c1f88013325c193af4895130a368",
    "line": "Grand.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1f/Moira_-_Grand.ogg/revision/latest?cb=20230914120608"
  },
  {
    "hero": "Moira",
    "ID": "627a1e2b264144753bdd150e609e49f1",
    "line": "I'm working.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/30/Moira_-_I%27m_working.ogg/revision/latest?cb=20230914120805"
  },
  {
    "hero": "Moira",
    "ID": "d128d23b247305373ca4277c44a99144",
    "line": "Idle hands are the devil's workshop.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/82/Moira_-_Idle_hands_are_the_devil%27s_workshop.ogg/revision/latest?cb=20230914120810"
  },
  {
    "hero": "Moira",
    "ID": "eb10f1033989259e286bfd3507be67d9",
    "line": "One hand gives, the other takes away.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/72/Moira_-_One_hand_gives%2C_the_other_takes_away.ogg/revision/latest?cb=20230914121029"
  },
  {
    "hero": "Moira",
    "ID": "e2132d6fefabc156b1f841c642f7728a",
    "line": "Stupidity is not a right.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/85/Moira_-_Stupidity_is_not_a_right.ogg/revision/latest?cb=20230914121211"
  },
  {
    "hero": "Moira",
    "ID": "cc524b5e3eb63752f985a055fecdcb97",
    "line": "The state of you!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/ad/Moira_-_The_state_of_you.ogg/revision/latest?cb=20230914121327"
  },
  {
    "hero": "Moira",
    "ID": "ff0d7f8ccdb6dd46a1708be003392b53",
    "line": "What are you on about?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/c6/Moira_-_What_are_you_on_about.ogg/revision/latest?cb=20230914121551"
  },
  {
    "hero": "Moira",
    "ID": "15b34b54a7756de08c08e3b20436ba71",
    "line": "You're a chancer.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/73/Moira_-_You%27re_a_chancer.ogg/revision/latest?cb=20230914121624"
  },
  {
    "hero": "Moira",
    "ID": "3a5a1610aca9c529440879b67809d5bb",
    "line": "Better living, through science.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/89/Moira_-_Better_living_through_science.ogg/revision/latest?cb=20230914120400"
  },
  {
    "hero": "Moira",
    "ID": "a6557b3fee12b62ef401f6e4e1290539",
    "line": "Performance enhanced.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0e/Moira_-_Performance_enhanced.ogg/revision/latest?cb=20230914121059"
  },
  {
    "hero": "Moira",
    "ID": "b293408122173da8ad53f4b03c598035",
    "line": "Expand Oíche shamhna shona duit. English: Happy Halloween (to you).",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0f/Moira_-_%28Irish%29_Happy_Halloween.ogg/revision/latest?cb=20230914120207"
  },
  {
    "hero": "Moira",
    "ID": "60f1d2b3eefe625dc941d2ad1d13a453",
    "line": "Despair has its own calms.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/bd/Moira_-_Despair_has_its_own_calms.ogg/revision/latest?cb=20230914120448"
  },
  {
    "hero": "Moira",
    "ID": "70b582b7c977c14a2e5daf840a01185c",
    "line": "Your ignorance frightens me.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/2d/Moira_-_Your_ignorance_frightens_me.ogg/revision/latest?cb=20230914121643"
  },
  {
    "hero": "Moira",
    "ID": "b0796a4ad9bd0f68130aa73613506f6b",
    "line": "Absolute zero.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/e4/Moira_-_Absolute_zero.ogg/revision/latest?cb=20230914120318"
  },
  {
    "hero": "Moira",
    "ID": "1301e4217c6ce23f4e6c6fdd9fa7ca85",
    "line": "The gift of knowledge.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/3c/Moira_-_The_gift_of_knowledge.ogg/revision/latest?cb=20230914121259"
  },
  {
    "hero": "Moira",
    "ID": "cd5c40a33282c094d428d08672c7da66",
    "line": "Expand Nollaig shona duit. English: Happy Christmas (to you). / Merry Christmas.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/6/61/Moira_-_%28Irish%29_Happy_Christmas.ogg/revision/latest?cb=20230914120207"
  },
  {
    "hero": "Moira",
    "ID": "12a34308cd58e9e3aade648edea28aea",
    "line": "Nothing but coal for you.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/10/Moira_-_Nothing_but_coal_for_you.ogg/revision/latest?cb=20230914121013"
  },
  {
    "hero": "Moira",
    "ID": "26b0a5f46e20c94a6ce22fa12f706d33",
    "line": "You've made a dog's breakfast of it.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/71/Moira_-_You%27ve_made_a_dog%27s_breakfast_of_it.ogg/revision/latest?cb=20230914121634"
  },
  {
    "hero": "Moira",
    "ID": "d9cda7f6c12ffeaa9744afa97ed13915",
    "line": "Expand Sláinte. English: Cheers. / Good health.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8a/Moira_-_%28Irish%29_Cheers.ogg/revision/latest?cb=20230914120159"
  },
  {
    "hero": "Moira",
    "ID": "3881b3889e47f64229284bedcc556f72",
    "line": "Expand Ar dóigh! English: Superb!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/10/Moira_-_%28Irish%29_Superb.ogg/revision/latest?cb=20230914120218"
  },
  {
    "hero": "Moira",
    "ID": "19c336aeaff9ea5bcc6cb3e0baf182ea",
    "line": "A tiger by the tail is still a tiger.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/2c/Moira_-_A_tiger_by_the_tail_is_still_a_tiger.ogg/revision/latest?cb=20230914120311"
  },
  {
    "hero": "Moira",
    "ID": "d1829d3abf13d1b6568a8e00a8d083ab",
    "line": "Unsavory.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/fc/Moira_-_Unsavory.ogg/revision/latest?cb=20230914121436"
  },
  {
    "hero": "Moira",
    "ID": "5960f0af96905dc2fc145505ee8ae99a",
    "line": "I put my faith in science.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/41/Moira_-_I_put_my_faith_in_science.ogg/revision/latest?cb=20230914120730"
  },
  {
    "hero": "Moira",
    "ID": "44132b357992eb9571cb5946d629599b",
    "line": "Get off the stage.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/5a/Moira_-_Get_off_the_stage.ogg/revision/latest?cb=20230914120600"
  },
  {
    "hero": "Moira",
    "ID": "6377204e667971a68096ade28e849f25",
    "line": "This is to my liking.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f5/Moira_-_This_is_to_my_liking.ogg/revision/latest?cb=20230914121408"
  },
  {
    "hero": "Moira",
    "ID": "f990e56fc9896e4fc4ab8fb98a33ef7f",
    "line": "You're mistaken.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/56/Moira_-_You%27re_mistaken.ogg/revision/latest?cb=20230914121627"
  },
  {
    "hero": "Moira",
    "ID": "0f2c9596187cdc071e5bf2409c9377a9",
    "line": "Clearly, evolution does not distribute its gifts equally.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/87/Moira_-_Clearly_evolution_does_not_distribute_its_gifts_equally.ogg/revision/latest?cb=20230914120426"
  },
  {
    "hero": "Moira",
    "ID": "327a319dd1eacc12d27c431e8e3629f2",
    "line": "Good news, everyone.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/ff/Moira_-_Good_news%2C_everyone.ogg/revision/latest?cb=20230914120606"
  },
  {
    "hero": "Moira",
    "ID": "b8b83f3a43c95c2d6594d198fa9f0e56",
    "line": "This was a triumph.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/bc/Moira_-_This_was_a_triumph.ogg/revision/latest?cb=20230914121412"
  },
  {
    "hero": "Moira",
    "ID": "e0cc40659773cd3a1ef7a0a37e35b85e",
    "line": "Unbelievable.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/24/Moira_-_Unbelievable_%281%29.ogg/revision/latest?cb=20230914121429"
  },
  {
    "hero": "Moira",
    "ID": "e629893a983f88bceb0eaa64234a0262",
    "line": "You can be improved.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/7a/Moira_-_You_can_be_improved.ogg/revision/latest?cb=20230914121612"
  },
  {
    "hero": "Moira",
    "ID": "d53e4ec403b03298f0df064c2229d187",
    "line": "I lay claim to divine fire.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/47/Moira_-_I_lay_claim_to_divine_fire.ogg/revision/latest?cb=20230914120720"
  },
  {
    "hero": "Moira",
    "ID": "f7abae3b11eecbec1fd9ef311b0be1ab",
    "line": "What reason have you to fear me?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/56/Moira_-_What_reason_have_you_to_fear_me.ogg/revision/latest?cb=20230914121555"
  },
  {
    "hero": "Moira",
    "ID": "3825f46fee7b0267287ad3f2bc48e499",
    "line": "Ah, you know yourself.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f7/Moira_-_You_know_yourself.ogg/revision/latest?cb=20230914121618"
  },
  {
    "hero": "Moira",
    "ID": "324c21a850fe7a48e2fd69874cc14a22",
    "line": "Master your fear.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1e/Moira_-_Master_your_fear.ogg/revision/latest?cb=20240223045110"
  },
  {
    "hero": "Moira",
    "ID": "e948b11915da500a68dc055bea755044",
    "line": "Oh, pathetic creation. So easily discarded.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/73/Moira_-_Oh%2C_pathetic_creation%2C_so_easily_discarded.ogg/revision/latest?cb=20240223045110"
  },
  {
    "hero": "Moira",
    "ID": "7ecf9c8b356bb82a5f1e48867d5db0c0",
    "line": "Expand Thar barr! English: Great!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/7b/Moira_-_%28Irish%29_Great.ogg/revision/latest?cb=20240504210551"
  },
  {
    "hero": "Moira",
    "ID": "2b3ad475c984ee70bda1ec22963c26e9",
    "line": "You will know my vengeance.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/6/63/Moira_-_You_will_know_my_vengeance.ogg/revision/latest?cb=20250220222342"
  },
  {
    "hero": "Moira",
    "ID": "1335e35fc73857475dc896c5bea44d19",
    "line": "I have no use of you.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0d/Moira_-_I_have_no_use_of_you.ogg/revision/latest?cb=20250220222342"
  },
  {
    "hero": "Moira",
    "ID": "e1490ae3d21a207092ef72bcddda6c57",
    "line": "Like black magic!",
    "audio_url": null
  },
  {
    "hero": "Moira",
    "ID": "437568170cd0fdd44e9bc04f183ed7d3",
    "line": "Aren't you just pathetic?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/c3/Moira_-_Aren%27t_you_just_pathetic.ogg/revision/latest?cb=20230914120340"
  },
  {
    "hero": "Moira",
    "ID": "c83974163863e6a8fe5a3dffb21cb8ff",
    "line": "Be beautiful in sin.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0f/Moira_-_Be_beautiful_in_sin.ogg/revision/latest?cb=20240123214038"
  },
  {
    "hero": "Moira",
    "ID": "d65390668eabf54d59547185765cf57f",
    "line": "I will stay in the shadows.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/5d/Moira_-_I_will_stay_in_the_shadows.ogg/revision/latest?cb=20240123214416"
  },
  {
    "hero": "Moira",
    "ID": "19ff0a63e569b0a55d7a80f811330767",
    "line": "I will find the answers to the mysteries of creation.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0c/Moira_-_I_will_find_the_answers_to_the_mysteries_of_creation.ogg/revision/latest?cb=20240223045110"
  },
  {
    "hero": "Moira",
    "ID": "6e4d6a696f478ec86e36fe108e0f421f",
    "line": "Something wicked this way comes.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/00/Moira_-_Something_wicked_this_way_comes.ogg/revision/latest?cb=20240123214714"
  }
]