[
  {
    "hero": "Ramattra",
    "ID": "a25be8d23347b981f2e670bbbd815439",
    "line": "I do not fight for myself. I never have.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/d9/Ramattra_-_I_do_not_fight_for_myself._I_never_have.ogg/revision/latest?cb=20230914131018"
  },
  {
    "hero": "Ramattra",
    "ID": "776242149974124d503929bbb0a0de55",
    "line": "Bittersweet, but fitting.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/4c/Ramattra_-_Bittersweet%2C_but_fitting.ogg/revision/latest?cb=20240211193357"
  },
  {
    "hero": "Ramattra",
    "ID": "8244e6aca9922a9ff7613deb30565dcb",
    "line": "Do your worst, or I will.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/10/Ramattra_-_Do_your_worst%2C_or_I_will.ogg/revision/latest?cb=20230914130824"
  },
  {
    "hero": "Ramattra",
    "ID": "4a3a54b61a8b98b28663f737f5031efa",
    "line": "I know what you're doing.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/01/Ramattra_-_I_know_what_you%27re_doing.ogg/revision/latest?cb=20230914131035"
  },
  {
    "hero": "Ramattra",
    "ID": "0f95a7193a0d6693aaaf3c9ec0cf7f5f",
    "line": "Ignore us at your peril.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/dd/Ramattra_-_Ignore_us_at_your_peril.ogg/revision/latest?cb=20230914131121"
  },
  {
    "hero": "Ramattra",
    "ID": "17ddd405262f2ef73b8e4701ce17598e",
    "line": "Only the merciful deserve mercy.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/83/Ramattra_-_Only_the_merciful_deserve_mercy.ogg/revision/latest?cb=20230914131333"
  },
  {
    "hero": "Ramattra",
    "ID": "37f1b9cc09cef57fa96ae8ea136380ba",
    "line": "They will fight us, and they will lose.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1a/Ramattra_-_They_will_fight_us._And_they_will_lose.ogg/revision/latest?cb=20230914131731"
  },
  {
    "hero": "Ramattra",
    "ID": "b2297da25503ecae4a2996477d6d2826",
    "line": "We cannot fail when we strive together.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8a/Ramattra_-_We_cannot_fail_when_we_strive_together.ogg/revision/latest?cb=20230914131838"
  },
  {
    "hero": "Ramattra",
    "ID": "023d4ee22c4d7773735cf92a9641b763",
    "line": "We will fight like cornered beasts.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/48/Ramattra_-_We_will_fight_like_cornered_beasts.ogg/revision/latest?cb=20230914131907"
  },
  {
    "hero": "Ramattra",
    "ID": "4a70c330d81415000b1f2b3ea3630c71",
    "line": "You have my attention.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/c6/Ramattra_-_You_have_my_attention.ogg/revision/latest?cb=20230914132004"
  },
  {
    "hero": "Ramattra",
    "ID": "fb5c7a2c88166d33aa31e6a46cd6b04b",
    "line": "Your arrogance will cost you.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/e9/Ramattra_-_Your_arrogance_will_cost_you.ogg/revision/latest?cb=20230914132033"
  },
  {
    "hero": "Ramattra",
    "ID": "0f73cd342f1f99ccbb9b90e28ecbe1ce",
    "line": "Justice is cruel; it demands sacrifice.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/e0/Ramattra_-_Justice_is_cruel._It_demands_sacrifice.ogg/revision/latest?cb=20230914131159"
  },
  {
    "hero": "Ramattra",
    "ID": "7738fdee4a26b4623d85543cd83e9a71",
    "line": "The galaxy will tremble before us!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/72/Ramattra_-_The_galaxy_will_tremble_before_us.ogg/revision/latest?cb=20230914131616"
  },
  {
    "hero": "Ramattra",
    "ID": "54e03b47230c9223637d238cfe60d21a",
    "line": "History will forgive me, even if you cannot.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/74/Ramattra_-_History_will_forgive_me%2C_even_if_you_cannot.ogg/revision/latest?cb=20230914130948"
  },
  {
    "hero": "Ramattra",
    "ID": "35883dae1672f282a1fa2338112b3525",
    "line": "I fought for peace for too long. I was a fool.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8f/Ramattra_-_I_fought_for_peace_for_too_long._I_was_a_fool.ogg/revision/latest?cb=20230914131020"
  },
  {
    "hero": "Ramattra",
    "ID": "b85f13779ff04e38db37a8489ca75eee",
    "line": "We did not start this war.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/a7/Ramattra_-_We_did_not_start_this_war.ogg/revision/latest?cb=20230914131841"
  },
  {
    "hero": "Ramattra",
    "ID": "e37f449d0c70d872be551596843bd806",
    "line": "Without fear, there is no fury.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/4b/Ramattra_-_Without_fear%2C_there_is_no_fury.ogg/revision/latest?cb=20240423123124"
  },
  {
    "hero": "Ramattra",
    "ID": "aee0ab4ec79bc3a65a87d797c672901b",
    "line": "This is no game. This is survival.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/a6/Ramattra_-_This_is_no_game._This_is_survival.ogg/revision/latest?cb=20240924133832"
  },
  {
    "hero": "Ramattra",
    "ID": "2a29495281024c3a92b7e329c35587ff",
    "line": "I am the guardian and the gateway.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/80/Ramattra_-_I_am_the_guardian_and_the_gateway.ogg/revision/latest?cb=20240924133908"
  },
  {
    "hero": "Ramattra",
    "ID": "17557f1caf7323ac5f28f74e69a0b450",
    "line": "Gods are mere tools. Built to foster fear, and wielded by the wicked.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/28/Ramattra_-_Gods_are_mere_tools._Built_to_foster_fear%2C_and_wielded_by_the_wicked.ogg/revision/latest?cb=20240920225444"
  },
  {
    "hero": "Ramattra",
    "ID": "20e3630c61b4cd470d30e44e26ef01a2",
    "line": "You are nothing but toil and trouble.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/7c/Ramattra_-_You_are_nothing_but_toil_and_trouble.ogg/revision/latest?cb=20241105085001"
  },
  {
    "hero": "Ramattra",
    "ID": "c92ab9b56a0fa765626e1ad8b41adf8a",
    "line": "Humanity will always insist on immortality.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/c6/Ramattra_-_Humanity_will_always_insist_on_immortality.ogg/revision/latest?cb=20260222075817"
  },
  {
    "hero": "Ramattra",
    "ID": "9de6467effe655578928d84f738a4801",
    "line": "You will regret your insolence when I free the Kraken.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/5b/Ramattra_-_You_will_regret_your_insolence_when_I_free_the_kraken.ogg/revision/latest?cb=20230914132029"
  },
  {
    "hero": "Ramattra",
    "ID": "d71d8681310f65c0441ce681710f28c2",
    "line": "Our lives are short. Will you share yours with me?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/a6/Ramattra_-_Our_lives_are_short._Will_you_share_yours_with_me.ogg/revision/latest?cb=20230914131345"
  },
  {
    "hero": "Ramattra",
    "ID": "aad506c775766d9eeb9cd507c775b0b9",
    "line": "Anything that stands in the way of our path be eliminated!",
    "audio_url": null
  },
  {
    "hero": "Ramattra",
    "ID": "c528050ce043591a57066eda7bed5e68",
    "line": "The battle is only the beginning.",
    "audio_url": null
  },
  {
    "hero": "Ramattra",
    "ID": "9a0e151b7992e049cfc820acc8c403cf",
    "line": "I roil with the fury of a detonating star! (Kabuki Ramattra Bundle)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/9f/Ramattra_-_I_roil_with_the_fury_of_a_detonating_star.ogg/revision/latest?cb=20230914131046"
  },
  {
    "hero": "Ramattra",
    "ID": "c68ce5ea9783087ea6e0a15878b4863b",
    "line": "I will win by any means! (Megatron Ramattra Bundle)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/4b/Ramattra_-_I_will_win_by_any_means.ogg/revision/latest?cb=20240924133947"
  },
  {
    "hero": "Ramattra",
    "ID": "b022d172aebf0dbbd5e6af03c32f3cf0",
    "line": "Power flows to the one who knows how. (Megatron Ramattra Bundle)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/21/Ramattra_-_Power_flows_to_the_one_who_knows_how.ogg/revision/latest?cb=20240924134027"
  },
  {
    "hero": "Ramattra",
    "ID": "5936004bac2bf0ae20867be480d83cb8",
    "line": "Epyon... show me the future! (Epyon Ramattra Bundle)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0d/Ramattra_-_Epyon..._show_me_the_future.ogg/revision/latest?cb=20260222075822"
  },
  {
    "hero": "Ramattra",
    "ID": "b0faf190e78bd0fb79373b6093a3a4fe",
    "line": "It is the strong who create the weak. (Epyon Ramattra Bundle)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0f/Ramattra_-_It_is_the_strong_who_create_the_weak.ogg/revision/latest?cb=20260222075820"
  }
]