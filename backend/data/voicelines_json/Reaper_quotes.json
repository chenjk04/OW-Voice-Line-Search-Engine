    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/51/Reaper_-_Was_that_all.ogg/revision/latest?cb=20230914133604"
  },
  {
    "hero": "Reaper",
    "ID": "108a3f19edbb67e01743be92ae33c868",
    "line": "You look like you've seen a ghost.",
