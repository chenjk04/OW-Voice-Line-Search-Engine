    "ID": "303f0fc5db43b99b2fa66296b49f1b86",
    "line": "Stand and fight, you cowards!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/92/Reaper_-_Stand_and_fight%2C_you_cowards.ogg/revision/latest?cb=20260305233933"
