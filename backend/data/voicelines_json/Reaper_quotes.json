  },
  {
    "hero": "Reaper",
    "ID": "0e136d466cc15183618573fdfce5cbe6",
    "line": "I'm not a psychopath. I'm a high-functioning psychopath.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/8b/Reaper_-_I%27m_not_a_psychopath._I%27m_a_high_functioning_psychopath.ogg/revision/latest?cb=20230914132818"
  },
  {
    "hero": "Reaper",
    "ID": "8a989a13dc9129499310e0dafc8f50e6",
    "line": "Next.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1b/Reaper_-_Next.ogg/revision/latest?cb=20230914133041"
  },
  {
    "hero": "Reaper",
    "ID": "f73a79c02472f43c3c9b60b23e8352e3",
