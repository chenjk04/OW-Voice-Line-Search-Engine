    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/93/Reaper_-_You_fools.ogg/revision/latest?cb=20260305233943"
  },
  {
    "hero": "Reaper",
    "ID": "45e32d4096cf3793f2da2e38ca23ba6b",
