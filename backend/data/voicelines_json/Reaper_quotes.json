    "hero": "Reaper",
    "ID": "aae209a3645c8e4c4054325ef7f0b078",
    "line": "You'll be deader than disco!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/d4/Reaper_-_You%27ll_be_deader_than_disco.ogg/revision/latest?cb=20260305233946"
  }
