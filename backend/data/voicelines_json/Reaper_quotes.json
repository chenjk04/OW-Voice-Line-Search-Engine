    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/3f/Reaper_-_Smile.ogg/revision/latest?cb=20230914133301"
  },
  {
    "hero": "Reaper",
    "ID": "2b06994afda92b163118e7774edbfa3d",
