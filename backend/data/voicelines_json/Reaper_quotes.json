  {
    "hero": "Reaper",
    "ID": "21ff793c9ec2b813748c1b56ea36ee36",
    "line": "Sneaking in undetected is my specialty.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/3d/Reaper_-_Sneaking_in_undetected_is_my_specialty.ogg/revision/latest?cb=20260305233929"
  },
  {
    "hero": "Reaper",
    "ID": "7197ad64c1a59eb94450e372bcafc178",
    "line": "What's so funny?",
