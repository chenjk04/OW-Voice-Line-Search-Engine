  },
  {
    "hero": "Reaper",
    "ID": "0c3eaae81139208662c40afb7b9838a0",
    "line": "Just win.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/90/Reaper_-_Just_win.ogg/revision/latest?cb=20230914132903"
  },
  {
    "hero": "Reaper",
    "ID": "721d5f4a70d6c235e20ed677fa1ae6dd",
    "line": "I work the graveyard shift.",
