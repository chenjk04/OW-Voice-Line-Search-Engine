  },
  {
    "hero": "Reaper",
    "ID": "e47db6ce973fd633efdc361af8fec647",
    "line": "I hate this job. (Cobra Commander Reaper Bundle)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/7c/Reaper_-_I_hate_this_job.ogg/revision/latest?cb=20260305233916"
  },
  {
    "hero": "Reaper",
    "ID": "725db1b28708fbd76837310aeba0fcbf",
