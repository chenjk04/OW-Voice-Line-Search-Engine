[
  {
    "hero": "Soldier:_76",
    "ID": "90321e664e1be457fd69b662d4ce15b8",
    "line": "I've still got it.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/7f/Soldier_76_-_I%27ve_still_got_it.ogg/revision/latest?cb=20230915000353"
  },
  {
    "hero": "Soldier:_76",
    "ID": "af150e6ca16583d568b97e3498d8692a",
    "line": "I'm an army of one.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/a4/Soldier_76_-_I%27m_an_army_of_one.ogg/revision/latest?cb=20230915000318"
  },
  {
    "hero": "Soldier:_76",
    "ID": "08a40f59bb493c780fa512ea782690e1",
    "line": "I didn't start this war... But I'm damn well gonna finish it.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/48/Soldier_76_-_I_didn%27t_start_this_war%2C_but_I%27m_damn_well_going_to_finish_it.ogg/revision/latest?cb=20230915000224"
  },
  {
    "hero": "Soldier:_76",
    "ID": "3f9453ad6a1246141a780132bad4acdf",
    "line": "Not on my watch.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/06/Soldier_76_-_Not_on_my_watch.ogg/revision/latest?cb=20230915000612"
  },
  {
    "hero": "Soldier:_76",
    "ID": "4011665e270b0ae191450f7ed9145906",
    "line": "Old soldiers never die, and they don't fade away.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/7c/Soldier_76_-_Old_soldiers_never_die..._and_they_don%27t_fade_away.ogg/revision/latest?cb=20230915000627"
  },
  {
    "hero": "Soldier:_76",
    "ID": "ea60836eaa91954f1bb6d72ef6c8d28c",
    "line": "Sit down!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/48/Soldier_76_-_Sit_down.ogg/revision/latest?cb=20230915000822"
  },
  {
    "hero": "Soldier:_76",
    "ID": "69ae691fd071f7023b5413e7d595e4b4",
    "line": "Smells like victory.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/de/Soldier_76_-_Smells_like_victory.ogg/revision/latest?cb=20230915000826"
  },
  {
    "hero": "Soldier:_76",
    "ID": "ac10059225dbb4d0b6471fd9a57aa610",
    "line": "That's \"sir\" to you.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/5f/Soldier_76_-_That%27s_sir%2C_to_you.ogg/revision/latest?cb=20230915001010"
  },
  {
    "hero": "Soldier:_76",
    "ID": "4f28db2c28af6a6e264be3a15513af88",
    "line": "What are you looking at?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/e7/Soldier_76_-_What_are_you_looking_at.ogg/revision/latest?cb=20230915001303"
  },
  {
    "hero": "Soldier:_76",
    "ID": "45b9117d51a553df7fa70c7b7d140d83",
    "line": "I'm the one who does his job, I'm thinking... you're the other one.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/7e/Soldier_76_-_I%27m_the_one_who_does_his_job._I%27m_thinking_you%27re_the_other_one.ogg/revision/latest?cb=20230915000338"
  },
  {
    "hero": "Soldier:_76",
    "ID": "96f3c68b77d335f44760b8fedb724dd7",
    "line": "You didn't make the cut.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/ef/Soldier_76_-_You_didn%27t_make_the_cut.ogg/revision/latest?cb=20230915001334"
  },
  {
    "hero": "Soldier:_76",
    "ID": "fe6bc5b673246d5f4f07681a963108a7",
    "line": "Young punks... Get off my lawn!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/ba/Soldier_76_-_Young_punks._Get_off_my_lawn.ogg/revision/latest?cb=20230915001406"
  },
  {
    "hero": "Soldier:_76",
    "ID": "bf17c41a7f021ad1e47e2471668d01ec",
    "line": "Bring the noise, bring the ruckus.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/bf/Soldier_76_-_Bring_the_noise%2C_bring_the_ruckus.ogg/revision/latest?cb=20230914235832"
  },
  {
    "hero": "Soldier:_76",
    "ID": "51222d68318d193fe5da2bad5c2335d9",
    "line": "You want a medal?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/ce/Soldier_76_-_You_want_a_medal.ogg/revision/latest?cb=20230915001354"
  },
  {
    "hero": "Soldier:_76",
    "ID": "1a8eca5d4ef20168920ebb209adfb126",
    "line": "Knock, knock.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/2d/Soldier_76_-_Knock%2C_knock.ogg/revision/latest?cb=20230915000439"
  },
  {
    "hero": "Soldier:_76",
    "ID": "02de28db125050878883c33fef31837a",
    "line": "Trick or treat.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0a/Soldier_76_-_Trick_or_treat.ogg/revision/latest?cb=20230915001155"
  },
  {
    "hero": "Soldier:_76",
    "ID": "99ef759faca6956fc0ef9dacf899c972",
    "line": "Merry Christmas.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/70/Soldier_76_-_Merry_Christmas.ogg/revision/latest?cb=20230915000518"
  },
  {
    "hero": "Soldier:_76",
    "ID": "0fb794671e91064712ba0d3b874e3a41",
    "line": "Stay frosty.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/15/Soldier_76_-_Stay_frosty.ogg/revision/latest?cb=20230915000854"
  },
  {
    "hero": "Soldier:_76",
    "ID": "f9bcd15e104846958be16f512282aebe",
    "line": "Respect your elders.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1b/Soldier_76_-_Respect_your_elders.ogg/revision/latest?cb=20230915000747"
  },
  {
    "hero": "Soldier:_76",
    "ID": "a4b13b63a38b907062b73c7a586da6f8",
    "line": "The rooster crows at midnight.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/3b/Soldier_76_-_The_rooster_crows_at_midnight.ogg/revision/latest?cb=20230915001037"
  },
  {
    "hero": "Soldier:_76",
    "ID": "52b8cffad339ee7b79e99cab502149a5",
    "line": "Don't call me a hero.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/15/Soldier_76_-_Don%27t_call_me_a_hero.ogg/revision/latest?cb=20230914235934"
  },
  {
    "hero": "Soldier:_76",
    "ID": "4793f8db0c3b59327da52047102fe62b",
    "line": "I'm not getting any younger.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/b9/Soldier_76_-_I%27m_not_getting_any_younger.ogg/revision/latest?cb=20230915000330"
  },
  {
    "hero": "Soldier:_76",
    "ID": "179bbbf3241cc4700c7e222ec0339b4c",
    "line": "Whatever you say...",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/ca/Soldier_76_-_Whatever_you_say.ogg/revision/latest?cb=20230915001312"
  },
  {
    "hero": "Soldier:_76",
    "ID": "095612a3bb05f2d03f572292eebd62b3",
    "line": "I'm not your father.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0e/Soldier_76_-_I%27m_not_your_father.ogg/revision/latest?cb=20230915000332"
  },
  {
    "hero": "Soldier:_76",
    "ID": "c2e81ebdd1ccedc1ca464621a037656f",
    "line": "You want something done right, you've got to do it yourself.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/bf/Soldier_76_-_You_want_something_done_right%2C_you%27ve_got_to_do_it_yourself.ogg/revision/latest?cb=20230915001355"
  },
  {
    "hero": "Soldier:_76",
    "ID": "d6db34f382ba1066255b5b115106d67c",
    "line": "You're the boss.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f5/Soldier_76_-_You%27re_the_boss.ogg/revision/latest?cb=20230915001404"
  },
  {
    "hero": "Soldier:_76",
    "ID": "a95339cfc8ddad401cc03c411ade4c80",
    "line": "Shape up! Or I'll have you cleaning stables.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/12/Soldier_76_-_Shape_up%2C_or_I%27ll_have_you_cleaning_stables.ogg/revision/latest?cb=20230915000810"
  },
  {
    "hero": "Soldier:_76",
    "ID": "107221dbfbd4e97661c9cf22f5783c66",
    "line": "Prepare to be boarded.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f7/Soldier_76_-_Prepare_to_be_boarded.ogg/revision/latest?cb=20230915000707"
  },
  {
    "hero": "Soldier:_76",
    "ID": "8708a9fad528b863ef2baa25e1c4efc0",
    "line": "Old habits die hard.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/6/6e/Soldier_76_-_Old_habits_die_hard.ogg/revision/latest?cb=20230915000625"
  },
  {
    "hero": "Soldier:_76",
    "ID": "aa7e7e9d2e24b99bf72135071acc05c4",
    "line": "One more story to tell around the fire.",
    "audio_url": null
  },
  {
    "hero": "Soldier:_76",
    "ID": "cdb671328bd4a5e8c29b5673df1f6546",
    "line": "What are you fighting for?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f1/Soldier_76_-_What_are_you_fighting_for.ogg/revision/latest?cb=20230915001302"
  },
  {
    "hero": "Soldier:_76",
    "ID": "15651b49669a0c21bbee748db88e86c5",
    "line": "This mobile suit can defeat any enemy.",
    "audio_url": null
  },
  {
    "hero": "Soldier:_76",
    "ID": "f6f8f4939dd9f27a735df13c1276025f",
    "line": "Space pirates have more honor than you. (Infinite Guard: 76 Soldier: 76 Bundle)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0a/Soldier_76_-_Space_pirates_have_more_honor_than_you.ogg/revision/latest?cb=20230915000849"
  },
  {
    "hero": "Soldier:_76",
    "ID": "43a559dd19bdce5a008ba2f391726b30",
