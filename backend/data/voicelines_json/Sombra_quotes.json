[
  {
    "hero": "Sombra",
    "ID": "402de2f1eecc7c75a5d652d89537d8bb",
    "line": "Where's the fun in playing fair?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/5e/Sombra_-_Where%27s_the_fun_in_playing_fair.ogg/revision/latest?cb=20230915002903"
  },
  {
    "hero": "Sombra",
    "ID": "516090d35e3239223db6aa9feaabc2a4",
    "line": "Boop!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/72/Sombra_-_Boop.ogg/revision/latest?cb=20230915001715"
  },
  {
    "hero": "Sombra",
    "ID": "9d1b3bcf9980d9e1176ca98335958b53",
    "line": "Did you mean to do that?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/84/Sombra_-_Did_you_mean_to_do_that.ogg/revision/latest?cb=20230915001754"
  },
  {
    "hero": "Sombra",
    "ID": "5c68e75d318696ad14f84374e5b11563",
    "line": "*scoff* Good one.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/86/Sombra_-_Good_one.ogg/revision/latest?cb=20230915001924"
  },
  {
    "hero": "Sombra",
    "ID": "f526044973b26e36484d91c51b89cbb7",
    "line": "Hack the planet.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f3/Sombra_-_Hack_the_planet.ogg/revision/latest?cb=20230915001945"
  },
  {
    "hero": "Sombra",
    "ID": "90456d08e0fc67ecf4f8363dbc98e17f",
    "line": "I think you're in over your head.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/6/67/Sombra_-_I_think_you%27re_in_over_your_head.ogg/revision/latest?cb=20230915002054"
  },
  {
    "hero": "Sombra",
    "ID": "66cb6e656d24260d1fc19a00f01d19d1",
    "line": "If you hold the information, you hold all the cards.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/6/61/Sombra_-_If_you_hold_the_information%2C_you_hold_all_the_cards.ogg/revision/latest?cb=20230915002134"
  },
  {
    "hero": "Sombra",
    "ID": "56d475e70f375ebc493cba64d1239445",
    "line": "Just squishing a bug.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/6/60/Sombra_-_Just_squishing_a_bug.ogg/revision/latest?cb=20230915002155"
  },
  {
    "hero": "Sombra",
    "ID": "a999d2aff7f8c06afc3f2d8f6ce36f9f",
    "line": "Mess with the best and die like the rest.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/b5/Sombra_-_Mess_with_the_best%2C_and_die_like_the_rest.ogg/revision/latest?cb=20230915002248"
  },
  {
    "hero": "Sombra",
    "ID": "c111028cc2382293fa1a97d34a3a51e6",
    "line": "You're just a glitch in the system.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/dd/Sombra_-_You%27re_just_a_glitch_in_the_system.ogg/revision/latest?cb=20230915003027"
  },
  {
    "hero": "Sombra",
    "ID": "c09b6b47ab51a63dc376ff8318aa209e",
    "line": "You're taking this very seriously.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/b5/Sombra_-_You%27re_taking_this_very_seriously.ogg/revision/latest?cb=20230915003037"
  },
  {
    "hero": "Sombra",
    "ID": "0a9ce3f6fa334a1f12a990f71e8a05ec",
    "line": "Expand ¡Asústame, panteón! Literal: Scare me, graveyard! English: Show me what you've got!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/af/Sombra_-_%28Spanish%29_Show_me_what_you%27ve_got.ogg/revision/latest?cb=20230915001548"
  },
  {
    "hero": "Sombra",
    "ID": "650ef467d0d8c798988554446ff045ee",
    "line": "Expand ¡De pelos! English: Cool!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/89/Sombra_-_%28Spanish%29_Cool.ogg/revision/latest?cb=20230915001456"
  },
  {
    "hero": "Sombra",
    "ID": "ddc7d1f46a860fdad14ed87defa486f8",
    "line": "I got some sun once. Didn't care for it.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/d1/Sombra_-_I_got_some_sun_once._Didn%27t_care_for_it.ogg/revision/latest?cb=20230915002031"
  },
  {
    "hero": "Sombra",
    "ID": "6a132b2e68f52dfe6330723e7be0769e",
    "line": "Try and keep up.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f5/Sombra_-_Try_and_keep_up.ogg/revision/latest?cb=20230915002708"
  },
  {
    "hero": "Sombra",
    "ID": "f5ee43dced74f6afe7137e73640ea302",
    "line": "Expand ¿Qué pex? English: What's up?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/d7/Sombra_-_%28Spanish%29_What%27s_up_%281%29.ogg/revision/latest?cb=20230915001607"
  },
  {
    "hero": "Sombra",
    "ID": "6f7ea81ccddd08f6b637ce2c2f0fbf7b",
    "line": "Aww, isn't that sweet?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/50/Sombra_-_Aw%2C_isn%27t_that_sweet.ogg/revision/latest?cb=20230915001645"
  },
  {
    "hero": "Sombra",
    "ID": "f30e6c30008c42cbbf52e53eeedac863",
    "line": "You trying to be scary?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/3b/Sombra_-_You_trying_to_be_scary.ogg/revision/latest?cb=20230915003001"
  },
  {
    "hero": "Sombra",
    "ID": "3dd8b26c301d08efa1a2eb44786fa2aa",
    "line": "You're not alone in here.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/b1/Sombra_-_You%27re_not_alone_in_here.ogg/revision/latest?cb=20230915003031"
  },
  {
    "hero": "Sombra",
    "ID": "ba1cdc19e47b584810f1b0461d5f750b",
    "line": "I can be nice.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/51/Sombra_-_I_can_be_nice.ogg/revision/latest?cb=20230915002019"
  },
  {
    "hero": "Sombra",
    "ID": "3aaac5ca6746e4285701018119e6aef9",
    "line": "I know who's been naughty.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/4/42/Sombra_-_I_know_who%27s_been_naughty.ogg/revision/latest?cb=20230915002040"
  },
  {
    "hero": "Sombra",
    "ID": "3da68bb7940d8d4711e069b3ad4dfb70",
    "line": "Who wants to buy me a present?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/37/Sombra_-_Who_wants_to_buy_me_a_present.ogg/revision/latest?cb=20230915002908"
  },
  {
    "hero": "Sombra",
    "ID": "a2511c8df861ef92e0303de395329e30",
    "line": "Expand ¡Feliz Navidad! English: Merry Christmas!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/03/Sombra_-_%28Spanish%29_Merry_Christmas.ogg/revision/latest?cb=20230915001530"
  },
  {
    "hero": "Sombra",
    "ID": "5084f93234c233701f6607c0f3bdc4de",
    "line": "Ooh, this one has teeth. * growls *",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/0f/Sombra_-_Ooh%2C_this_one_has_teeth._%28growls%29.ogg/revision/latest?cb=20230915002342"
  },
  {
    "hero": "Sombra",
    "ID": "17a6b00286e39fbc49f497897b7ece6d",
    "line": "You work too hard.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/92/Sombra_-_You_work_too_hard.ogg/revision/latest?cb=20230915003010"
  },
  {
    "hero": "Sombra",
    "ID": "c4125b6e570c29899212383d8505c4ce",
    "line": "You're easily impressed.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/a6/Sombra_-_You%27re_easily_impressed.ogg/revision/latest?cb=20230915003020"
  },
  {
    "hero": "Sombra",
    "ID": "aa6b57e16c12038d843b50622c34400d",
    "line": "You're in the doghouse.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/be/Sombra_-_You%27re_in_the_doghouse.ogg/revision/latest?cb=20230915003025"
  },
  {
    "hero": "Sombra",
    "ID": "c6ef3fb81af11707f4b030ac3b702575",
    "line": "I'd like to say it was nice working with you, but it wasn't.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/3/37/Sombra_-_I%27d_like_to_say_it_was_nice_working_with_you%2C_but_it_wasn%27t.ogg/revision/latest?cb=20230915002104"
  },
  {
    "hero": "Sombra",
    "ID": "6d0e4fc1f32442a33c3710ecf00d049f",
    "line": "I'd love to stay and chat, but... I'm not going to.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/a7/Sombra_-_I%27d_love_to_stay_and_chat%2C_but_I%27m_not_going_to.ogg/revision/latest?cb=20230915002105"
  },
  {
    "hero": "Sombra",
    "ID": "7bf313c4be1fb26a925dfb1f0321d7e9",
    "line": "Expand No le saques. English: Don't be scared.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/8/89/Sombra_-_%28Spanish%29_Don%27t_be_a_coward.ogg/revision/latest?cb=20230915001501"
  },
  {
    "hero": "Sombra",
    "ID": "2d15ce266990df0852964a585727a1b8",
    "line": "Expand ¡Volvamos a la medianoche! English: Let's return to the midnight!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/04/Sombra_-_%28Spanish%29_Let%27s_go_back_to_la_Medianoche.ogg/revision/latest?cb=20230915001527"
  },
  {
    "hero": "Sombra",
    "ID": "98008256d35292765daf5730d16240c1",
    "line": "I need a drink.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/b9/Sombra_-_I_need_a_drink.ogg/revision/latest?cb=20230915002045"
  },
  {
    "hero": "Sombra",
    "ID": "0b2816f8a271a9426bd372c2c331cd67",
    "line": "Let's not do that again.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/d5/Sombra_-_Let%27s_not_do_that_again.ogg/revision/latest?cb=20230915002232"
  },
  {
    "hero": "Sombra",
    "ID": "f56d6f5bb06f962289dc989641da66bc",
    "line": "We're a good team. You're lucky to have me.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/5e/Sombra_-_We%27re_a_good_team._You%27re_lucky_to_have_me.ogg/revision/latest?cb=20230915002816"
  },
  {
    "hero": "Sombra",
    "ID": "f0fc2b4697c90feea05584d874ef3841",
    "line": "Were you done talking?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/7/7e/Sombra_-_Were_you_done_talking.ogg/revision/latest?cb=20230915002842"
  },
  {
    "hero": "Sombra",
    "ID": "98ea9bca4bdccdec946877a3d68e4d5e",
    "line": "I've got the Midas touch! That's a good thing, right?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/53/Sombra_-_I%27ve_got_the_Midas_touch%21_That%27s_a_good_thing%2C_right.ogg/revision/latest?cb=20230915002127"
  },
  {
    "hero": "Sombra",
    "ID": "d57ac62a2649c80af97520dae45da0ba",
    "line": "No one is greater than the game.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/c5/Sombra_-_No_one_is_greater_than_the_game.ogg/revision/latest?cb=20240516130326"
  },
  {
    "hero": "Sombra",
    "ID": "639aa838a6f140d43afb4f34239edc47",
    "line": "There are no secrets between us, right?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/0/04/Sombra_-_There_are_no_secrets_between_us%2C_right.ogg/revision/latest?cb=20240516130328"
  },
  {
    "hero": "Sombra",
    "ID": "d0ae5b67f5ce60cf32e0a176e32163cc",
    "line": "You want to see something real scary?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/20/Sombra_-_You_want_to_see_something_real_scary.ogg/revision/latest?cb=20241105170556"
  },
  {
    "hero": "Sombra",
    "ID": "934901b5bc5acc303be9b8523fea89da",
    "line": "Hope you cleared your browsing history.",
    "audio_url": null
  },
  {
    "hero": "Sombra",
    "ID": "190c7677b013dfbf962b97b574a5ff45",
    "line": "Found a bug. (Quicksilver Sombra Bundle)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/99/Sombra_-_Found_a_bug.ogg/revision/latest?cb=20230915001855"
  },
  {
    "hero": "Sombra",
    "ID": "611b7c6243f77d7bbafeac63bfd0097f",
    "line": "You'll rue the day you crossed the Bride of Junkenstein.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/bb/Sombra_-_You%27ll_rue_the_day_you_crossed_the_Bride_of_Junkenstein.ogg/revision/latest?cb=20230915003017"
  }
]