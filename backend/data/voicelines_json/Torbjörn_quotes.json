[
  {
    "hero": "Torbjörn",
    "ID": "e6f8fae27d0677c0e6dba37230fde679",
    "line": "Hard work pays off.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/96/Torbj%C3%B6rn_-_Hard_work_pays_off.ogg/revision/latest?cb=20230915011211"
  },
  {
    "hero": "Torbjörn",
    "ID": "17411056b5491382812d8a19dd8478aa",
    "line": "Completion date? * chuckle * When it's done.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/6/6c/Torbj%C3%B6rn_-_Completion_date._When_it%27s_done.ogg/revision/latest?cb=20230915010924"
  },
  {
    "hero": "Torbjörn",
    "ID": "827a15a39ec5d833cfe652b2f5d1373a",
    "line": "Don't get caught with your beard in the letterbox!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/a/ab/Torbj%C3%B6rn_-_Don%27t_get_caught_with_your_beard_in_the_letterbox.ogg/revision/latest?cb=20230915010953"
  },
  {
    "hero": "Torbjörn",
    "ID": "97c7e07b9f989833e05af029c58d4915",
    "line": "For the last time, I'm Swedish!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/e5/Torbj%C3%B6rn_-_For_the_last_time%2C_I%27m_Swedish.ogg/revision/latest?cb=20230915011108"
  },
  {
    "hero": "Torbjörn",
    "ID": "9ebd13d73a34b4c9e1a7cf15fa485999",
    "line": "I'm giving it all I got!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/5/59/Torbj%C3%B6rn_-_I%27m_giving_it_all_I%27ve_got.ogg/revision/latest?cb=20230915011437"
  },
  {
    "hero": "Torbjörn",
    "ID": "e9d261b3fe2b5e47f3fc52dc0c1d59a9",
    "line": "Ironclad!",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "19634791464a57d29856778cc75331a2",
    "line": "Let's not buy the pig while it's still in the bag.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/e/eb/Torbj%C3%B6rn_-_Let%27s_not_buy_the_pig_while_it%27s_still_in_the_bag.ogg/revision/latest?cb=20230915011650"
  },
  {
    "hero": "Torbjörn",
    "ID": "c3807e20d14b712763d96e1115f14938",
    "line": "People always underestimate the engineers.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/2/23/Torbj%C3%B6rn_-_People_always_underestimate_the_engineers.ogg/revision/latest?cb=20230915011926"
  },
  {
    "hero": "Torbjörn",
    "ID": "e3f941fc7abe9e0ec173b91a01d73130",
    "line": "Some assembly required.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/12/Torbj%C3%B6rn_-_Some_assembly_required.ogg/revision/latest?cb=20230915012049"
  },
  {
    "hero": "Torbjörn",
    "ID": "fed6cf6df327c4b8898c37ae8aea872a",
    "line": "Torbjööörn Lindholm!",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "67e5fb1f321a57fd41d53136b4304af8",
    "line": "Ugh, leave this to an expert.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/9/9a/Torbj%C3%B6rn_-_Leave_this_to_an_expert.ogg/revision/latest?cb=20230915011630"
  },
  {
    "hero": "Torbjörn",
    "ID": "095906cd8bfb0bc4eff3190c966c6d37",
    "line": "*chuckle* Working as intended...",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/17/Torbj%C3%B6rn_-_Working_as_intended.ogg/revision/latest?cb=20230915012639"
  },
  {
    "hero": "Torbjörn",
    "ID": "7e19be86f188b746b7f64a3cee0a0958",
    "line": "You're making a chicken out of a feather!",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/d/d6/Torbj%C3%B6rn_-_You%27re_making_a_chicken_out_of_a_feather.ogg/revision/latest?cb=20230915012714"
  },
  {
    "hero": "Torbjörn",
    "ID": "7d13f7aa493ea8d836ba00cf29c8521e",
    "line": "Haha! There's more where that came from.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "12b54d20fdf14184d4ae8c0896d7b466",
    "line": "There's no prize for coming in second!",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "3244c1a266c7e5d75c4860d8a7628bfc",
    "line": "I smell trouble brewing.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "4a0518f07fdb3e1f40145da4cb83cc30",
    "line": "* chuckles * If you build it... they will die.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "80f5ce9da497149000eb1d0f901d5d1d",
    "line": "It's not a costume!",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "a5886ed1be95b68bc1cb78cc2cedecdc",
    "line": "Mind the beard.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "340d50f4f292b2d52d94096db54d2dd8",
    "line": "The viking sought a dragon. But a dragon found him first.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "5d2c9b0e652dd3df428603c8ed29b186",
    "line": "Give me a warm fire and a book on thermodynamic alloys.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "befa099c737214a3981c64786f7cd8de",
    "line": "Haha, expert craftsmanship!",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "b34f5158125c841b241626f182df96a4",
    "line": "Made to order!",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "6359be8a7a1d8c6d08e8c5663f74b1be",
    "line": "Everyone, get in here!",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "e2f3d2e724c73ac4470f1492c5558360",
    "line": "Too hot for you?",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "4a6fc01efd0c98751a91a32d51919cfb",
    "line": "Bingo!",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "6b929ae1bade66b1d555a93c26b4c949",
    "line": "Just start hammering.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "c30534c6e014641db36496c90d29e349",
    "line": "* scoff * Poor craftsman blame their tools.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "90e0b53307a4c079ef957b087283ed8e",
    "line": "Hear me, baby? Hold together.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "729d3a101b986397b006062ace314124",
    "line": "How riveting.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "722806669350a25b7adce926f7c33084",
    "line": "Trust me.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "1bb80bb85c07280787cd3137d072a68f",
    "line": "Now, why didn't I think of that?",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "9ebe81d2b0f2c13520408ba2f0088830",
    "line": "* laughs * You should try my meatballs.",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "35770ec7f44938e677979fdc79e0468a",
    "line": "My beard is older than you are.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/c2/Torbj%C3%B6rn_-_My_beard_is_older_than_you_are.ogg/revision/latest?cb=20230915011747"
  },
  {
    "hero": "Torbjörn",
    "ID": "2e624ec141ada30093a665c5f36b1b0f",
    "line": "Someone call for the repairman?",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/1/1a/Torbj%C3%B6rn_-_Someone_call_for_the_repairman.ogg/revision/latest?cb=20230915012052"
  },
  {
    "hero": "Torbjörn",
    "ID": "7b3ca6abc10d7223cb640f37ae5586f2",
    "line": "Pumpkin spice... latte!? Tell me that isn't real.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/b5/Torbj%C3%B6rn_-_Pumpkin_spice..._latte._Tell_me_that_isn%27t_real.ogg/revision/latest?cb=20240423113403"
  },
  {
    "hero": "Torbjörn",
    "ID": "0c7c85415dfaa81a6344ae5431c30c77",
    "line": "You won't sink my battleship! (Captain Torbjörn Bundle)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/f/f9/Torbj%C3%B6rn_-_You_won%27t_sink_my_battleship.ogg/revision/latest?cb=20230915012708"
  },
  {
    "hero": "Torbjörn",
    "ID": "35f06644206c7af9787f7bc31f3436a4",
    "line": "Feel the fury of the mountain. (Diamond Magni Torbjörn Bundle)",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/c/cb/Torbj%C3%B6rn_-_Feel_the_fury_of_the_mountain.ogg/revision/latest?cb=20241025205256"
  },
  {
    "hero": "Torbjörn",
    "ID": "80d974231f0121eb782faf37eeff18ad",
    "line": "Stop rocking the boat!",
    "audio_url": null
  },
  {
    "hero": "Torbjörn",
    "ID": "e91896e3f9a880e9c36493fa9d707c66",
    "line": "Sometimes you just have to do it yourself.",
    "audio_url": "https://static.wikia.nocookie.net/overwatch_gamepedia/images/b/b6/Torbj%C3%B6rn_-_Sometimes_you_just_have_to_do_it_yourself.ogg/revision/latest?cb=20230915012103"
  }
]